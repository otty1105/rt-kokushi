NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 会員登録完了メール送信用（Gmail SMTP）
GMAIL_USER=medical.output@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Supabase Database Webhook（auth.usersへのINSERTを検知）の認証用シークレット
# Webhook設定時にヘッダー x-webhook-secret として同じ値を指定する
SUPABASE_WEBHOOK_SECRET=your-random-secret
